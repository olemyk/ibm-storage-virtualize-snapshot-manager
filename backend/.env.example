# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:3000

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/snapshots.db

# For PostgreSQL (uncomment and configure if using postgres):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=snapshots
# DB_USER=snapshots
# DB_PASSWORD=your_password

# Security Configuration (REQUIRED - Generate secure random keys)
JWT_SECRET=your-jwt-secret-key-here-change-this
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log