# IBM Storage Virtualize Snapshot Manager - Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_NAME=snapshots
DB_USER=snapshots
# REQUIRED: Set a strong password (minimum 16 characters recommended)
DB_PASSWORD=changeme_secure_password_here

# ============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# ============================================================================
# Generate JWT_SECRET with: openssl rand -base64 32
# Must be at least 32 characters
JWT_SECRET=

# Generate ENCRYPTION_KEY with: openssl rand -base64 32
# Must be exactly 32 bytes when base64 decoded
ENCRYPTION_KEY=

# ============================================================================
# SERVER CONFIGURATION (Optional)
# ============================================================================
# Logging level: debug, info, warn, error
LOG_LEVEL=info

# External hostname for CORS (if accessing from different domain)
# EXTERNAL_HOSTNAME=your-domain.com

# ============================================================================
# PORT CONFIGURATION (Optional)
# ============================================================================
# Frontend ports (default: 80 for HTTP, 443 for HTTPS)
# FRONTEND_HTTP_PORT=80
# FRONTEND_HTTPS_PORT=443

# ============================================================================
# SSL CERTIFICATE CONFIGURATION (Optional)
# ============================================================================
# Path to custom SSL certificates directory
# If not set, uses ./ssl directory with self-signed certificates
# SSL_CERT_PATH=./ssl

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit the .env file to version control
# 2. Generate strong, unique values for JWT_SECRET and ENCRYPTION_KEY
# 3. Use a strong database password (16+ characters, mixed case, numbers, symbols)
# 4. For production, replace self-signed certificates with proper SSL certs
# 5. Run ./deploy/setup.sh to auto-generate security keys
